#: extension.js:113
msgid "Text will be here"
msgstr "Text wird hier angezeigt"

#: extension.js:187
msgid "Type here to search..."
msgstr "Text eingeben, um zu suchen…"

#: extension.js:256 prefs.js:257
msgid "Private mode"
msgstr "Privater Modus"

#: extension.js:270 prefs.js:259
msgid "Clear history"
msgstr "Verlauf löschen"

#: extension.js:315
msgid "Settings"
msgstr "Einstellungen"

#: extension.js:338
msgid "Clipboard is empty"
msgstr "Zwischenablage ist leer"

#: extension.js:626
msgid "Clear all?"
msgstr "Alles löschen?"

#: extension.js:627
msgid "Are you sure you want to delete all clipboard items?"
msgstr "Soll die Zwischenablage wirklich geleert werden?"

#: extension.js:628
msgid "This operation cannot be undone."
msgstr "Diese Aktion kann nicht rückgängig gemacht werden."

#: extension.js:630
msgid "Clear"
msgstr "Löschen"

#: extension.js:630 extension.js:801
msgid "Cancel"
msgstr "Abbrechen"

#: extension.js:645
msgid "Clipboard history cleared"
msgstr "Verlauf der Zwischenablage gelöscht"

#: extension.js:648
msgid "Clipboard history cleared automatically"
msgstr "Verlauf der Zwischenablage automatisch gelöscht"

#: extension.js:800
msgid "Copied to clipboard"
msgstr "In Zwischenablage kopiert"

#: prefs.js:31
msgid "History Size"
msgstr "Größe des Verlaufs"

#: prefs.js:40
msgid "Preview Size (characters)"
msgstr "Vorschaugröße (Zeichen)"

#: prefs.js:49
msgid "Max cache file size (MB)"
